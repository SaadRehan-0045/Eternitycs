    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Service card hover effects */
        .service-card {
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
        }
        
        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        
        .service-card:hover .service-image {
            transform: scale(1.05);
        }
        
        .service-card:hover .service-overlay {
            opacity: 1;
        }
        
        /* Service image container */
        .service-image-container {
            position: relative;
            overflow: hidden;
        }
        
        .service-image {
            transition: transform 0.5s ease;
        }
        
        .service-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(to top, rgba(30, 64, 175, 0.9) 0%, rgba(37, 99, 235, 0.5) 50%, transparent 100%);
            opacity: 0.6;
            transition: opacity 0.3s ease;
        }
        
        .dark .service-overlay {
            background: linear-gradient(to top, rgba(30, 58, 138, 0.9) 0%, rgba(30, 64, 175, 0.6) 50%, transparent 100%);
        }
        
        /* Section background */
        .services-bg {
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        }
        
        .dark .services-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        
        /* Service badge colors */
        .badge-blue { background-color: #3b82f6; }
        .badge-purple { background-color: #8b5cf6; }
        .badge-green { background-color: #10b981; }
        .badge-amber { background-color: #f59e0b; }
        .badge-pink { background-color: #ec4899; }
        .badge-indigo { background-color: #6366f1; }
        .badge-red { background-color: #ef4444; }
    </style>
