<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eternity Care Services</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'slide-in': 'slideIn 0.3s ease-out',
                        'slide-out': 'slideOut 0.3s ease-in',
                    }
                }
            }
        }
    </script>
    <style>
        * { scrollbar-width: none; -ms-overflow-style: none; }
        *::-webkit-scrollbar { display: none; }
        * { transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease; }
        .dark body { color-scheme: dark; }
        .mobile-drawer-enter { animation: slideIn 0.3s ease-out forwards; }
        .mobile-drawer-exit { animation: slideOut 0.3s ease-in forwards; }
        @keyframes slideIn { 0% { transform: translateX(-100%); opacity: 0; } 100% { transform: translateX(0); opacity: 1; } }
        @keyframes slideOut { 0% { transform: translateX(0); opacity: 1; } 100% { transform: translateX(-100%); opacity: 0; } }

        /* Custom header with white background in light mode, dark background in dark mode, and a faint background image */
        .custom-header {
            position: relative;
            background-color: white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            z-index: 50;
        }
        .dark .custom-header {
            background-color: #111827; /* gray-900 */
        }
        .custom-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://plus.unsplash.com/premium_photo-1681996691019-638215f6ceb1?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-size: cover;
            background-position: center;
            opacity: 0.15; /* increased from 0.05 to 0.15 for better visibility */
            pointer-events: none;
            z-index: 0;
        }
        .custom-header > * {
            position: relative;
            z-index: 1;
        }

        /* Top bar styles for light/dark */
        .top-bar {
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
            background: rgba(0, 0, 0, 0.02);
            backdrop-filter: blur(10px);
        }
        .dark .top-bar {
            border-bottom: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05);
        }

        /* Contact link colors */
        .contact-link {
            color: #374151; /* gray-700 */
            transition: all 0.3s ease;
            padding: 0.25rem 0.5rem;
            border-radius: 0.5rem;
        }
        .contact-link:hover {
            color: #97d700; /* new green-yellow */
            background: rgba(0, 0, 0, 0.05);
            transform: translateX(5px);
        }
        .dark .contact-link {
            color: rgba(255,255,255,0.8);
        }
        .dark .contact-link:hover {
            color: #c8ff4d; /* lighter green-yellow for dark mode */
            background: rgba(255,255,255,0.1);
        }

        /* Icon background for social/contact icons */
        .icon-bg {
            background: rgba(0, 0, 0, 0.05);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }
        .icon-bg:hover {
            background: #97d700;
            border-color: #97d700;
            transform: translateY(-2px);
        }
        .dark .icon-bg {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
        }
        .dark .icon-bg:hover {
            background: #c8ff4d;
            border-color: #c8ff4d;
        }

        /* Contact icon circular */
        .contact-icon {
            width: 40px;
            height: 40px;
            background: rgba(0, 0, 0, 0.05);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #374151; /* gray-700 */
            transition: all 0.3s ease;
        }
        .contact-icon:hover {
            background: #97d700;
            color: white;
            transform: translateY(-2px);
        }
        .dark .contact-icon {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            color: white;
        }
        .dark .contact-icon:hover {
            background: #c8ff4d;
        }

        /* Primary buttons (now used only for theme toggle) */
        .btn-primary {
            background: #2563eb; /* primary-600 */
            border: none;
            padding: 0.5rem 1.25rem;
            border-radius: 50px;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            color: white;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background: #1d4ed8; /* primary-700 */
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .dark .btn-primary {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            color: white;
        }
        .dark .btn-primary:hover {
            background: #2563eb;
            border-color: #2563eb;
        }

        /* Navigation link style (for left items) */
        .nav-link {
            color: #374151;
            font-weight: 500;
            text-transform: uppercase;
            font-size: 0.875rem;
            letter-spacing: 0.05em;
            transition: color 0.3s ease;
            padding: 0.5rem 0;
        }
        .nav-link:hover {
            color: #97d700;
        }
        .dark .nav-link {
            color: rgba(255,255,255,0.9);
        }
        .dark .nav-link:hover {
            color: #c8ff4d;
        }

        /* Button style for REFERRAL and CONTACT – fixed text color for dark mode */
        .nav-button {
            background-color: #97d700; /* rgb(151,215,0) */
            color: #1f2937; /* dark text for light mode */
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.875rem;
            letter-spacing: 0.05em;
            padding: 0.5rem 1.25rem;
            border-radius: 9999px; /* full rounded */
            transition: all 0.3s ease;
            display: inline-block;
            box-shadow: 0 2px 4px rgba(151, 215, 0, 0.2);
        }
        .nav-button:hover {
            background-color: #87c000; /* slightly darker */
            color: #111827; /* keep dark text on hover in light mode */
            transform: translateY(-2px);
            box-shadow: 0 8px 12px -4px rgba(151, 215, 0, 0.3);
        }
        .dark .nav-button {
            background-color: #b0e030; /* lighter variant for dark mode */
            color: white; /* white text in dark mode */
            box-shadow: 0 2px 4px rgba(176, 224, 48, 0.3);
        }
        .dark .nav-button:hover {
            background-color: #97d700; /* original green-yellow */
            color: white; /* keep white text on hover in dark mode */
        }

        /* Theme toggle button hover – use new color */
        #themeToggleDesktop:hover, #themeToggleMobile:hover {
            background-color: #97d700 !important;
            border-color: #97d700 !important;
            color: #111827 !important;
        }

        /* Icon colors in top bar – now use new green-yellow */
        .top-bar i {
            color: #97d700;
        }
        .dark .top-bar i {
            color: #c8ff4d;
        }

        /* Dropdown menu styles */
        .dropdown-menu {
            min-width: 280px;
        }
        .dropdown-section {
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
        }
        .dark .dropdown-section {
            border-bottom: 1px solid rgba(55, 65, 81, 0.5);
        }
        .dropdown-section:last-child {
            border-bottom: none;
        }

        .mobile-dropdown-item { color: #1e293b !important; }
        .mobile-dropdown-item:hover { color: #97d700 !important; background: rgba(151, 215, 0, 0.1); }
        .dark .mobile-dropdown-item { color: rgba(255,255,255,0.8) !important; }
        .dark .mobile-dropdown-item:hover { color: #c8ff4d !important; background: rgba(200, 255, 77, 0.2); }

        @media (max-width: 640px) {
            .mobile-top-bar { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; }
        }

        /* Additional text color adjustments for light mode */
        .custom-header .text-white {
            color: #1f2937; /* gray-800 */
        }
        .dark .custom-header .text-white {
            color: white;
        }
        .custom-header .text-white\/90 {
            color: rgba(31, 41, 55, 0.9);
        }
        .dark .custom-header .text-white\/90 {
            color: rgba(255,255,255,0.9);
        }
        .custom-header .text-white\/80 {
            color: rgba(31, 41, 55, 0.8);
        }
        .dark .custom-header .text-white\/80 {
            color: rgba(255,255,255,0.8);
        }
        .custom-header .text-white\/70 {
            color: rgba(31, 41, 55, 0.7);
        }
        .dark .custom-header .text-white\/70 {
            color: rgba(255,255,255,0.7);
        }
        .custom-header .border-white\/10 {
            border-color: rgba(0, 0, 0, 0.1);
        }
        .dark .custom-header .border-white\/10 {
            border-color: rgba(255,255,255,0.1);
        }
        .custom-header .border-white\/30 {
            border-color: rgba(0, 0, 0, 0.3);
        }
        .dark .custom-header .border-white\/30 {
            border-color: rgba(255,255,255,0.3);
        }
        .custom-header .bg-white\/20 {
            background: rgba(0, 0, 0, 0.05);
        }
        .dark .custom-header .bg-white\/20 {
            background: rgba(255,255,255,0.2);
        }
        .custom-header .bg-white\/20:hover {
            background: #97d700;
        }
        .dark .custom-header .bg-white\/20:hover {
            background: #97d700;
        }
        .custom-header .text-primary-300 {
            color: #97d700;
        }
        .dark .custom-header .text-primary-300 {
            color: #c8ff4d;
        }
    </style>
</head>
