<!-- COMPLETE REFERRAL FORM JAVASCRIPT - COPY THIS -->
<!-- ============================================ -->
<script>
    // ============================================
    // REFERRAL FORM HANDLER
    // ============================================
    
    // Toast notification function
    function showToast(message, type = 'success') {
        // Remove any existing toast
        const existingToast = document.querySelector('.toast');
        if (existingToast) {
            existingToast.remove();
        }
        
        // Create toast element
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        
        // Add icon based on type
        const icon = type === 'success' ? 'ri-checkbox-circle-fill' : 'ri-error-warning-fill';
        const iconColor = type === 'success' ? 'text-green-500' : 'text-red-500';
        
        toast.innerHTML = `
            <div class="flex items-start">
                <i class="${icon} ${iconColor} text-2xl mr-3"></i>
                <div>
                    <p class="font-medium ${type === 'success' ? 'text-green-600' : 'text-red-600'} dark:text-white">
                        ${type === 'success' ? 'Success!' : 'Error!'}
                    </p>
                    <p class="text-gray-600 dark:text-gray-300 mt-1">${message}</p>
                </div>
                <button onclick="this.parentElement.parentElement.remove()" class="ml-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <i class="ri-close-line text-xl"></i>
                </button>
            </div>
        `;
        
        document.body.appendChild(toast);
        
        // Auto remove after 5 seconds
        setTimeout(() => {
            if (toast.parentElement) {
                toast.remove();
            }
        }, 5000);
    }

    // Handle referral form submission
    async function handleReferralSubmit(event) {
        event.preventDefault();
        
        const form = event.target;
        const formData = new FormData(form);
        const submitButton = document.getElementById('referralSubmitBtn');
        const originalButtonText = submitButton.innerHTML;
        
        // Get form values for validation
        const participantName = formData.get('participantName');
        const participantPhone = formData.get('participantPhone');
        const participantEmail = formData.get('participantEmail');
        const postalCode = formData.get('postalCode');
        const dob = formData.get('dob');
        const referrerEmail = formData.get('referrerEmail');
        const referrerPhone = formData.get('referrerPhone');
        
        // Client-side validation for required fields
        if (!participantName || !participantPhone) {
            showToast('Participant name and phone number are required fields', 'error');
            return false;
        }
        
        // Phone validation for participant
        const participantPhoneDigits = participantPhone.replace(/\D/g, '');
        if (participantPhoneDigits.length < 8) {
            showToast('Please enter a valid participant phone number (minimum 8 digits)', 'error');
            return false;
        }
        
        // Email validation if provided
        if (participantEmail) {
            const emailRegex = /^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/i;
            if (!emailRegex.test(participantEmail)) {
                showToast('Please enter a valid email address for participant', 'error');
                return false;
            }
        }
        
        // Email validation for referrer if provided
        if (referrerEmail) {
            const emailRegex = /^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/i;
            if (!emailRegex.test(referrerEmail)) {
                showToast('Please enter a valid email address for referrer', 'error');
                return false;
            }
        }
        
        // Phone validation for referrer if provided
        if (referrerPhone) {
            const referrerPhoneDigits = referrerPhone.replace(/\D/g, '');
            if (referrerPhoneDigits.length < 8) {
                showToast('Please enter a valid referrer phone number (minimum 8 digits)', 'error');
                return false;
            }
        }
        
        // Postal code validation if provided
        if (postalCode && !/^\d{4}$/.test(postalCode)) {
            showToast('Please enter a valid 4-digit postal code', 'error');
            return false;
        }
        
        // DOB validation if provided
        if (dob && !/^\d{2}\/\d{2}\/\d{4}$/.test(dob)) {
            showToast('Please enter date of birth in DD/MM/YYYY format', 'error');
            return false;
        }
        
        // Show loading state
        submitButton.innerHTML = '<i class="ri-loader-4-line animate-spin mr-3"></i> Submitting...';
        submitButton.disabled = true;
        
        try {
            // Convert FormData to URLSearchParams
            const urlEncodedData = new URLSearchParams();
            for (let [key, value] of formData.entries()) {
                urlEncodedData.append(key, value);
            }
            
            console.log('Sending referral data...', Object.fromEntries(formData.entries()));
            
            const response = await fetch('/referral-form', {
                method: 'POST',
                body: urlEncodedData,
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            
            // Try to parse JSON response
            let result;
            try {
                result = await response.json();
            } catch (e) {
                console.error('Could not parse JSON response:', e);
                result = { success: false, error: 'Server returned an invalid response' };
            }
            
            if (response.ok && result.success) {
                // Show success message
                showToast(result.message || 'Thank you for your referral! Our team will contact you within 24-48 hours.', 'success');
                form.reset(); // Clear the form
                
                // Reset validation styling
                document.querySelectorAll('#referralForm input').forEach(input => {
                    input.classList.remove('border-green-500', 'border-red-500');
                });
                
                // Scroll to top to show the message
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                // Show error message from server or default
                showToast(result.error || result.message || 'An error occurred. Please try again.', 'error');
                console.error('Server error:', result);
            }
        } catch (error) {
            console.error('Fetch Error:', error);
            showToast('Network error. Please check your connection and try again.', 'error');
        } finally {
            // Reset button
            submitButton.innerHTML = originalButtonText;
            submitButton.disabled = false;
        }
        
        return false;
    }

    // Add real-time validation styling
    document.addEventListener('DOMContentLoaded', function() {
        const referralForm = document.getElementById('referralForm');
        if (referralForm) {
            // Add submit event listener (in addition to onsubmit attribute)
            referralForm.addEventListener('submit', handleReferralSubmit);
            
            // Add input validation styling
            const inputs = referralForm.querySelectorAll('input');
            inputs.forEach(input => {
                input.addEventListener('input', function() {
                    if (this.checkValidity()) {
                        this.classList.add('border-green-500');
                        this.classList.remove('border-red-500');
                    } else {
                        this.classList.add('border-red-500');
                        this.classList.remove('border-green-500');
                    }
                });
            });
        }
        
        console.log('Referral form JavaScript loaded successfully');
    });
</script>

<!-- Add toast styles -->
<style>
    .toast {
        position: fixed;
