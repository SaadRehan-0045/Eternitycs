<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eternity Care Services - Footer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'spin-slow': 'spin 2s linear infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition for all elements */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Better dark mode contrast */
        .dark body {
            color-scheme: dark;
        }
        
        /* Custom footer with white background in light mode, dark background in dark mode, and faint background image */
        .custom-footer {
            position: relative;
            background-color: white;
            box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
            z-index: 10;
            border-top: 4px solid #97d700; /* Added green-yellow top border (151,215,0) */
        }
        .dark .custom-footer {
            background-color: #111827; /* gray-900 */
            border-top: 4px solid #b0e030; /* Slightly lighter for dark mode but still green-yellow family */
        }
        .custom-footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://plus.unsplash.com/premium_photo-1664302163944-cfbe76709490?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            pointer-events: none;
            z-index: 0;
        }
        .custom-footer > * {
            position: relative;
            z-index: 1;
        }

        /* Form input styling – light mode */
        .form-input {
            background-color: rgba(0, 0, 0, 0.02);
            border: 1px solid rgba(0, 0, 0, 0.1);
            color: #1f2937;
            width: 100%;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
        }
        .form-input:focus {
            outline: none;
            box-shadow: 0 0 0 2px rgba(151, 215, 0, 0.5);
            border-color: transparent;
        }
        .dark .form-input {
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
        }
        .dark .form-input:focus {
            box-shadow: 0 0 0 2px rgba(151, 215, 0, 0.8);
        }

        /* Validation styling */
        .form-input:invalid:not(:placeholder-shown) {
            border-color: #ef4444;
        }
        .form-input:valid:not(:placeholder-shown) {
            border-color: #10b981;
        }
        .dark .form-input:valid:not(:placeholder-shown) {
            border-color: #34d399;
        }

        /* Placeholder styling */
        .form-input::placeholder {
            color: rgba(0, 0, 0, 0.4);
            font-size: 0.9rem;
        }
        .dark .form-input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        /* Label styling */
        .form-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.25rem;
            color: #1f2937;
        }
        .dark .form-label {
            color: white;
        }

        /* Required star color */
        .required-star {
            color: #ef4444;
            margin-left: 2px;
        }

        /* Icon colors – using #97d700 in light mode, lighter variant in dark mode */
        .footer-icon {
            color: #97d700;
        }
        .dark .footer-icon {
            color: #c8ff4d; /* lighter green-yellow for dark mode */
        }

        /* Social media link styling */
        .social-link {
            display: flex;
            align-items: center;
            color: #1f2937;
            transition: all 0.2s ease;
        }
        .social-link:hover {
            color: #97d700;
            padding-left: 0.5rem;
        }
        .dark .social-link {
            color: rgba(255, 255, 255, 0.8);
        }
        .dark .social-link:hover {
            color: #c8ff4d;
        }

        /* Send message button – green-yellow background with dark text */
        .send-button {
            background-color: #97d700;
            color: #1f2937;
            font-weight: 600;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            box-shadow: 0 2px 4px rgba(151, 215, 0, 0.2);
            width: 100%;
        }
        .send-button:hover {
            background-color: #87c000;
            transform: translateY(-2px);
            box-shadow: 0 8px 12px -4px rgba(151, 215, 0, 0.3);
        }
        .send-button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }
        .dark .send-button {
            background-color: #b0e030; /* lighter for dark mode */
            color: #111827;
        }
        .dark .send-button:hover:not(:disabled) {
            background-color: #97d700;
        }

        /* Card backgrounds with blur */
        .footer-card {
            background-color: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 0.5rem;
            padding: 1.5rem;
            height: 100%;
            transition: all 0.3s ease;
        }
        .footer-card:hover {
            background-color: rgba(255, 255, 255, 0.7);
        }
        .dark .footer-card {
            background-color: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .dark .footer-card:hover {
            background-color: rgba(0, 0, 0, 0.4);
        }

        /* Section headings */
        .footer-heading {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1f2937;
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
        }
        .dark .footer-heading {
            color: white;
        }

        /* Divider */
        .footer-divider {
            border-top: 1px solid rgba(0, 0, 0, 0.1);
        }
        .dark .footer-divider {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Contact links */
        .contact-link {
            display: flex;
            align-items: center;
            color: #4b5563;
            transition: color 0.2s ease;
        }
        .contact-link:hover {
            color: #97d700;
        }
        .dark .contact-link {
            color: rgba(255, 255, 255, 0.8);
        }
        .dark .contact-link:hover {
            color: #c8ff4d;
        }

        /* Text colors */
        .footer-text {
            color: #4b5563;
        }
        .dark .footer-text {
            color: rgba(255, 255, 255, 0.8);
        }
        .footer-text-muted {
            color: #6b7280;
        }
        .dark .footer-text-muted {
            color: rgba(255, 255, 255, 0.6);
        }
        .footer-text-strong {
            color: #1f2937;
            font-weight: 500;
        }
        .dark .footer-text-strong {
            color: white;
        }

        /* Brand heading in green-yellow */
        .brand-heading {
            color: #97d700;
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .dark .brand-heading {
            color: #c8ff4d;
        }
        
        /* Logo image styling */
        .footer-logo {
            width: 28px;
            height: 28px;
            object-fit: contain;
            margin: 0 0.25rem;
            filter: brightness(0.8);
            transition: filter 0.3s ease;
        }
        .dark .footer-logo {
            filter: brightness(1.2);
        }

        /* Toast notification styles */
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 16px 24px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            z-index: 9999;
            animation: slideIn 0.3s ease;
            max-width: 400px;
        }
        .dark .toast {
            background: #1f2937;
            color: white;
        }
        .toast.success {
            border-left: 4px solid #10b981;
        }
        .toast.error {
            border-left: 4px solid #ef4444;
        }
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex items-end">
