     /* Fixed overlay using RGB (151, 215, 0) with gradient variation */
.parallax-overlay {
    background: linear-gradient(135deg, rgba(151, 215, 0, 0.95) 0%, rgba(151, 215, 0, 0.9) 50%, rgba(151, 215, 0, 0.85) 100%);
    position: absolute;
